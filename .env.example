# Deep Search Research — local environment template
# Copy needed values into your shell/session manager. Do not commit real secrets.

# ------------------------------
# Embedding
# ------------------------------
# Supported today: stub | openai-compatible
DEEP_SEARCH_EMBEDDING_PROVIDER=stub
DEEP_SEARCH_EMBEDDING_MODEL=
DEEP_SEARCH_EMBEDDING_BASE_URL=
DEEP_SEARCH_EMBEDDING_API_KEY=
DEEP_SEARCH_EMBEDDING_DIMENSIONS=1024
DEEP_SEARCH_EMBEDDING_TIMEOUT=30

# ------------------------------
# Reranker
# ------------------------------
# Supported today: stub | jina | http-json | embedding-sim
DEEP_SEARCH_RERANKER_PROVIDER=stub
DEEP_SEARCH_RERANKER_MODEL=
DEEP_SEARCH_RERANKER_URL=
DEEP_SEARCH_RERANKER_API_KEY=
DEEP_SEARCH_RERANKER_TIMEOUT=30
# Optional shortcut when using Jina hosted reranker
JINA_API_KEY=

# ------------------------------
# OpenSearch
# ------------------------------
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=deep-search-mvp
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VECTOR_DIMS=1024
OPENSEARCH_VERIFY_TLS=true

# ------------------------------
# HTTP/cache behavior
# ------------------------------
DEEP_SEARCH_CACHE_DIR=
DEEP_SEARCH_REQUEST_INTERVAL=0.6
